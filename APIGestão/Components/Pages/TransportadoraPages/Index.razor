@page "/transportadoras"
@rendermode InteractiveServer
@using APIGestão.API.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Transportadoras</PageTitle>

<h1>Transportadoras</h1>

<p>
    <a href="transportadoras/create" class="btn btn-primary">+ Nova Transportadora</a>
</p>

@if (transportadoras == null)
{
    <p class="loading"><em>Carregando...</em></p>
}
else if (!transportadoras.Any())
{
    <p>Nenhuma transportadora cadastrada.</p>
}
else
{
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Razão Social</th>
                    <th>Nome Fantasia</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Tipo Transporte</th>
                    <th>Prazo Entrega (dias)</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in transportadoras)
                {
                    <tr>
                        <td>@t.RazaoSocial</td>
                        <td>@t.NomeFantasia</td>
                        <td>@t.Telefone</td>
                        <td>@t.Email</td>
                        <td>@t.TipoTransporte</td>
                        <td>@t.PrazoEntrega</td>
                        <td>
                            <span class="@(t.Status ? "badge-ativo" : "badge-inativo")">
                                @(t.Status ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td>
                            <div class="table-actions">
                                <a href="@($"transportadoras/edit?id={t.ID}")" class="action-edit">Editar</a>
                                <a href="@($"transportadoras/details?id={t.ID}")" class="action-detail">Detalhes</a>
                                <a href="@($"transportadoras/delete?id={t.ID}")" class="action-delete">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Transportadora>? transportadoras;

    protected override async Task OnInitializedAsync()
    {
        transportadoras = await Http.GetFromJsonAsync<List<Transportadora>>("api/transportadora");
    }
}
