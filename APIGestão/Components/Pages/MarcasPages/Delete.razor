@page "/produtos/delete"
@rendermode InteractiveServer
@using APIGest„o.API.Models
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Excluir Produto</PageTitle>

<h1>Excluir Produto</h1>
<p style="color:#e74c3c; margin-bottom:1rem;">?? Tem certeza que deseja excluir este produto?</p>

@if (produto is null)
{
    <p class="loading"><em>Carregando...</em></p>
}
else
{
    <div class="detail-card">
        <dl class="row">
            <dt>Nome</dt>
            <dd>@produto.Nome</dd>
            <dt>ID Marca</dt>
            <dd>@produto.IDMarca</dd>
            <dt>Quantidade</dt>
            <dd>@produto.Quantidade</dd>
            <dt>Tipo Mercadoria</dt>
            <dd>@produto.TipoMercadoria</dd>
            <dt>Status</dt>
            <dd>
                <span class="@(produto.Status ? "badge-ativo" : "badge-inativo")">
                    @(produto.Status ? "Ativo" : "Inativo")
                </span>
            </dd>
            <dt>Data Cadastro</dt>
            <dd>@produto.DataCadastro?.ToString("dd/MM/yyyy")</dd>
        </dl>
        <div style="margin-top:1.5rem; display:flex; gap:0.5rem;">
            <button class="btn btn-danger" @onclick="DeleteProduto">Confirmar Exclus„o</button>
            <a href="/produtos" class="btn btn-secondary">Cancelar</a>
        </div>
    </div>
}

@code {
    private Produtos? produto;

    [SupplyParameterFromQuery]
    private int ID { get; set; }

    protected override async Task OnInitializedAsync()
    {
        produto = await Http.GetFromJsonAsync<Produtos>($"api/produtos/{ID}");
        if (produto is null)
            NavigationManager.NotFound();
    }

    private async Task DeleteProduto()
    {
        var response = await Http.DeleteAsync($"api/produtos/{ID}");
        if (response.IsSuccessStatusCode)
            NavigationManager.NavigateTo("/produtos");
    }
}
