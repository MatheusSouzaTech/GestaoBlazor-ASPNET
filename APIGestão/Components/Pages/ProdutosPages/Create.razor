@page "/produtos/create"
@rendermode InteractiveServer
@using APIGestăo.API.Models
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Novo Produto</PageTitle>

<h1>Novo Produto</h1>

@if (!string.IsNullOrEmpty(erro))
{
    <div class="alert alert-danger">@erro</div>
}

<div class="form-card">
    <EditForm Model="Produto" OnValidSubmit="AddProduto">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-errors" role="alert"/>

        <div class="mb-3">
            <label for="nome" class="form-label">Nome</label>
            <InputText id="nome" @bind-Value="Produto.Nome" class="form-control" />
            <ValidationMessage For="() => Produto.Nome" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Marca</label>

            <InputSelect @bind-Value="Produto.IDMarca" class="form-control">
                <option value="0" disabled>Selecione uma marca</option>

                @foreach (var marca in Marcas)
                {
                    <option value="@marca.ID">
                        @marca.Nome
                    </option>
                }
            </InputSelect>

            <ValidationMessage For="() => Produto.IDMarca" class="text-danger" />
        </div>
        <div class="mb-3">
            <label for="quantidade" class="form-label">Quantidade</label>
            <InputNumber id="quantidade" @bind-Value="Produto.Quantidade" class="form-control" />
            <ValidationMessage For="() => Produto.Quantidade" class="text-danger" />
        </div>
        <div class="mb-3">
            <label for="tipomercadoria" class="form-label">Tipo Mercadoria</label>
            <InputText id="tipomercadoria" @bind-Value="Produto.TipoMercadoria" class="form-control" />
            <ValidationMessage For="() => Produto.TipoMercadoria" class="text-danger" />
        </div>
        <div class="mb-3">
            <label class="form-label">Status</label><br />
            <InputCheckbox id="status" @bind-Value="Produto.Status" class="form-check-input" />
            <label for="status" style="margin-left: 0.5rem;">Ativo</label>
        </div>
        <div class="mb-3">
            <label for="datacadastro" class="form-label">Data Cadastro</label>
            <InputDate id="datacadastro" @bind-Value="Produto.DataCadastro" class="form-control" />
            <ValidationMessage For="() => Produto.DataCadastro" class="text-danger" />
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:1.5rem;">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a href="/produtos" class="btn btn-secondary">Cancelar</a>
        </div>
    </EditForm>
</div>

@code {
    private List<Marcas> Marcas = new();
    private Produtos Produto { get; set; } = new() { DataCadastro = DateOnly.FromDateTime(DateTime.Today) };

    protected override async Task OnInitializedAsync()
    {
        Marcas = await Http.GetFromJsonAsync<List<Marcas>>("api/marcas");
    }

    private string? erro;

    private async Task AddProduto()
    {
        var response = await Http.PostAsJsonAsync("api/produtos", Produto);

        if (response.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/produtos");
        }
        else
        {
            erro = await response.Content.ReadAsStringAsync();
        }
    }
}
