@page "/fornecedores"
@using ModelsLibrary.Models
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Fornecedores — GestãoPro</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Fornecedores</div>
        <div class="page-subtitle">Gestão de fornecedores cadastrados</div>
    </div>
    <div class="page-actions">
        <a href="cadastro" class="btn btn-secondary">← Voltar</a>
        <a href="fornecedores/create" class="btn btn-primary">+ Novo Fornecedor</a>
    </div>
</div>

<div class="card">
    @if (fornecedores == null)
    {
        <div class="loading-spinner"><div class="spinner"></div> Carregando...</div>
    }
    else if (!fornecedores.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
            <p>Nenhum fornecedor cadastrado.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="erp-table">
                <thead>
                    <tr><th>#</th><th>Razão Social</th><th>CNPJ</th><th>Status</th><th>Ações</th></tr>
                </thead>
                <tbody>
                    @foreach (var f in fornecedores)
                    {
                        <tr>
                            <td class="text-muted small">@f.Id</td>
                            <td><strong>@f.RazaoSocial</strong></td>
                            <td class="small">@f.CNPJ</td>
                            <td>
                                @if (f.Ativo)
                                { <span class="badge badge-success">Ativo</span> }
                                else
                                { <span class="badge badge-danger">Inativo</span> }
                            </td>
                            <td>
                                <a href="@($"fornecedores/edit/{f.Id}")" class="btn btn-sm btn-secondary">Editar</a>
                                <a href="@($"fornecedores/delete/{f.Id}")" class="btn btn-sm btn-danger ms-2">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Fornecedor>? fornecedores;

    protected override async Task OnInitializedAsync()
    {
        fornecedores = await Http.GetFromJsonAsync<List<Fornecedor>>("api/fornecedores");
    }
}
