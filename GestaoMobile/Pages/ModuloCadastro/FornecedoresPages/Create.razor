@page "/fornecedores/create"
@using ModelsLibrary.Models
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Novo Fornecedor — GestãoPro</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Novo Fornecedor</div>
        <div class="page-subtitle">Preencha os dados para cadastrar um novo fornecedor</div>
    </div>
    <a href="fornecedores" class="btn btn-secondary">← Voltar</a>
</div>

<div class="card">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="alert alert-danger">@erro</div>
        }
        <EditForm Model="fornecedor" OnValidSubmit="Salvar">
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-summary-errors" />

            <div class="form-section">
                <div class="form-section-title">Dados do Fornecedor</div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Razão Social</label>
                        <InputText @bind-Value="fornecedor.RazaoSocial" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">CNPJ</label>
                        <InputText @bind-Value="fornecedor.CNPJ" class="form-control" placeholder="00.000.000/0000-00" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">E-mail</label>
                        <InputText @bind-Value="fornecedor.Email" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Telefone</label>
                        <InputText @bind-Value="fornecedor.Telefone" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="form-check mb-4">
                <InputCheckbox @bind-Value="fornecedor.Ativo" class="form-check-input" id="ativoCreate" />
                <label class="form-check-label" for="ativoCreate">Fornecedor ativo</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Salvar Fornecedor</button>
                <a href="fornecedores" class="btn btn-secondary">Cancelar</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private Fornecedor fornecedor = new();
    private string erro = string.Empty;

    private async Task Salvar()
    {
        erro = string.Empty;
        var resp = await Http.PostAsJsonAsync("api/fornecedores", fornecedor);
        var resultado = await resp.Content.ReadFromJsonAsync<RespostaApi>();
        if (resp.IsSuccessStatusCode)
            Nav.NavigateTo("fornecedores");
        else
            erro = resultado?.Mensagem ?? "Erro ao salvar fornecedor.";
    }

    private record RespostaApi(string Mensagem);
}
