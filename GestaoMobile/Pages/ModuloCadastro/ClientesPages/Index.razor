@page "/clientes"
@using ModelsLibrary.Models
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Clientes — GestãoPro</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Clientes</div>
        <div class="page-subtitle">Base de clientes cadastrados</div>
    </div>
    <div class="page-actions">
        <a href="cadastro" class="btn btn-secondary">← Voltar</a>
        <a href="clientes/create" class="btn btn-primary">+ Novo Cliente</a>
    </div>
</div>

<div class="card">
    @if (clientes == null)
    {
        <div class="loading-spinner"><div class="spinner"></div> Carregando...</div>
    }
    else if (!clientes.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
            </svg>
            <p>Nenhum cliente cadastrado.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nome</th>
                        <th>CPF / CNPJ</th>
                        <th>Telefone</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in clientes)
                    {
                        <tr>
                            <td class="text-muted small">@c.Id</td>
                            <td><strong>@c.Nome</strong></td>
                            <td class="small">@c.CPF_CNPJ</td>
                            <td>@c.Telefone</td>
                            <td>
                                @if (c.Ativo)
                                { <span class="badge badge-success">Ativo</span> }
                                else
                                { <span class="badge badge-danger">Inativo</span> }
                            </td>
                            <td>
                                <a href="@($"clientes/edit/{c.Id}")" class="btn btn-sm btn-secondary">Editar</a>
                                <a href="@($"clientes/delete/{c.Id}")" class="btn btn-sm btn-danger ms-2">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Cliente>? clientes;

    protected override async Task OnInitializedAsync()
    {
        clientes = await Http.GetFromJsonAsync<List<Cliente>>("api/clientes");
    }
}
