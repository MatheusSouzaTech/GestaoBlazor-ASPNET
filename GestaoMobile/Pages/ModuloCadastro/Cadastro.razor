@page "/cadastro"

<PageTitle>Cadastros — GestãoPro</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Módulos de Cadastro</div>
        <div class="page-subtitle">Selecione um cadastro para gerenciar</div>
    </div>
    <a href="" class="btn btn-secondary">← Voltar</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="module-grid">
            <a href="empresas" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M9 21v-5h6v5"/></svg>
                </div>
                <span class="module-card-label">Empresas</span>
            </a>
            <a href="clientes" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                </div>
                <span class="module-card-label">Clientes</span>
            </a>
            <a href="fornecedores" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                </div>
                <span class="module-card-label">Fornecedores</span>
            </a>
            <a href="transportadoras" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                </div>
                <span class="module-card-label">Transportadoras</span>
            </a>
            <a href="produtos" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                </div>
                <span class="module-card-label">Produtos</span>
            </a>
            <a href="marcas" class="module-card">
                <div class="module-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                </div>
                <span class="module-card-label">Marcas</span>
            </a>
        </div>
    </div>
</div>
