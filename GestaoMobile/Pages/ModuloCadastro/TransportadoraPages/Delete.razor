@page "/transportadoras/delete/{id:int}"
@using ModelsLibrary.Models
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Excluir Transportadora — GestãoPro</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Excluir Transportadora</div>
        <div class="page-subtitle">Esta ação não pode ser desfeita</div>
    </div>
    <a href="transportadoras" class="btn btn-secondary">← Voltar</a>
</div>

@if (transportadora == null)
{
    <div class="loading-spinner"><div class="spinner"></div> Carregando...</div>
}
else
{
    <div class="card" style="max-width:520px">
        <div class="card-body">
            <div class="alert alert-warning">
                Você está prestes a excluir permanentemente a transportadora <strong>@transportadora.Nome</strong>. Deseja continuar?
            </div>
            @if (!string.IsNullOrEmpty(erro))
            {
                <div class="alert alert-danger">@erro</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="Excluir">Confirmar Exclusão</button>
                <a href="transportadoras" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Transportadora? transportadora;
    private string erro = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        transportadora = await Http.GetFromJsonAsync<Transportadora>($"api/transportadoras/{Id}");
    }

    private async Task Excluir()
    {
        erro = string.Empty;
        var resp = await Http.DeleteAsync($"api/transportadoras/{Id}");
        var resultado = await resp.Content.ReadFromJsonAsync<RespostaApi>();
        if (resp.IsSuccessStatusCode)
            Nav.NavigateTo("transportadoras");
        else
            erro = resultado?.Mensagem ?? "Erro ao excluir transportadora.";
    }

    private record RespostaApi(string Mensagem);
}
