@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="erp-shell @(sidebarOpen ? "sidebar-open" : "")">

    <aside class="erp-sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                </svg>
            </div>
            <span class="brand-name">GestãoPro</span>
        </div>

        <nav class="sidebar-nav">

            <!-- Principal -->
            <div class="nav-section-label">Principal</div>
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span>Dashboard</span>
            </NavLink>

            <!-- Cadastros (submenu) -->
            <div class="nav-section-label">Cadastros</div>
            <div class="nav-group">
                <button class="nav-group-toggle @(cadastrosOpen ? "open" : "") @(CadastrosTemAtivo ? "has-active" : "")"
                        @onclick="ToggleCadastros">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
                    </svg>
                    <span>Cadastros</span>
                    <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="nav-submenu @(cadastrosOpen ? "open" : "")">
                    <NavLink class="nav-subitem" href="empresas">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M9 21v-5h6v5"/>
                        </svg>
                        <span>Empresas</span>
                    </NavLink>
                    <NavLink class="nav-subitem" href="clientes">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                        <span>Clientes</span>
                    </NavLink>
                    <NavLink class="nav-subitem" href="fornecedores">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        </svg>
                        <span>Fornecedores</span>
                    </NavLink>
                    <NavLink class="nav-subitem" href="transportadoras">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="3" width="15" height="13"/>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                        <span>Transportadoras</span>
                    </NavLink>
                </div>
            </div>

            <!-- Estoque (submenu) -->
            <div class="nav-section-label">Estoque</div>
            <div class="nav-group">
                <button class="nav-group-toggle @(estoqueOpen ? "open" : "") @(EstoqueTemAtivo ? "has-active" : "")"
                        @onclick="ToggleEstoque">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                    </svg>
                    <span>Estoque</span>
                    <svg class="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="nav-submenu @(estoqueOpen ? "open" : "")">
                    <NavLink class="nav-subitem" href="produtos">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                        </svg>
                        <span>Produtos</span>
                    </NavLink>
                    <NavLink class="nav-subitem" href="marcas">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                            <line x1="7" y1="7" x2="7.01" y2="7"/>
                        </svg>
                        <span>Marcas</span>
                    </NavLink>
                </div>
            </div>

            <!-- Administração -->
            <div class="nav-section-label">Administração</div>
            <NavLink class="nav-item" href="usuarios">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
                <span>Usuários</span>
            </NavLink>

        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">@_inicial</div>
                <div class="user-info">
                    <span class="user-name">@_nomeUsuario</span>
                    <span class="user-role">@_loginUsuario</span>
                </div>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>

    <div class="erp-main">
        <header class="erp-topbar">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-brand-mobile">GestãoPro</div>
            <div class="topbar-spacer"></div>
            <div class="topbar-actions">
                <div class="topbar-user">
                    <div class="topbar-avatar">@_inicial</div>
                    <span class="d-none d-md-inline">@_nomeUsuario</span>
                </div>
                <button class="topbar-logout" @onclick="Sair" title="Sair do sistema">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    <span class="d-none d-md-inline">Sair</span>
                </button>
            </div>
        </header>

        <main class="erp-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool   sidebarOpen    = false;
    private bool   cadastrosOpen  = false;
    private bool   estoqueOpen    = false;
    private string _nomeUsuario   = "Usuário";
    private string _loginUsuario  = "";
    private string _inicial       = "U";

    // Rotas que pertencem ao grupo Cadastros
    private static readonly string[] _rotasCadastros =
        ["empresas", "clientes", "fornecedores", "transportadoras"];

    // Rotas que pertencem ao grupo Estoque
    private static readonly string[] _rotasEstoque =
        ["produtos", "marcas"];

    private bool CadastrosTemAtivo => RotaAtiva(_rotasCadastros);
    private bool EstoqueTemAtivo   => RotaAtiva(_rotasEstoque);

    private bool RotaAtiva(string[] prefixos)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimStart('/').ToLower();
        return prefixos.Any(p => path == p || path.StartsWith(p + "/"));
    }

    protected override async Task OnInitializedAsync()
    {
        var usuario = await Auth.GetUsuarioLogadoAsync();
        if (usuario is not null)
        {
            _nomeUsuario  = usuario.Nome ?? usuario.Login ?? "Usuário";
            _loginUsuario = usuario.Login ?? "";
            _inicial      = _nomeUsuario.Length > 0 ? _nomeUsuario[0].ToString().ToUpper() : "U";
        }

        // Abre automaticamente o grupo cujo item está ativo
        cadastrosOpen = CadastrosTemAtivo;
        estoqueOpen   = EstoqueTemAtivo;

        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Mantém o submenu correto aberto ao navegar
        if (CadastrosTemAtivo) cadastrosOpen = true;
        if (EstoqueTemAtivo)   estoqueOpen   = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private void ToggleSidebar()   => sidebarOpen   = !sidebarOpen;
    private void ToggleCadastros() => cadastrosOpen  = !cadastrosOpen;
    private void ToggleEstoque()   => estoqueOpen    = !estoqueOpen;

    private async Task Sair()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }
}


