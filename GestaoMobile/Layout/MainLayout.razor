@inherits LayoutComponentBase

<div class="erp-shell @(sidebarOpen ? "sidebar-open" : "")">

    <!-- Sidebar -->
    <aside class="erp-sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                </svg>
            </div>
            <span class="brand-name">GestãoPro</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span>Dashboard</span>
            </NavLink>

            <div class="nav-section-label">Cadastros</div>
            <NavLink class="nav-item" href="empresas">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 21h18M3 7l9-4 9 4M4 7v14M20 7v14M9 21v-5h6v5"/>
                </svg>
                <span>Empresas</span>
            </NavLink>
            <NavLink class="nav-item" href="clientes">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
                <span>Clientes</span>
            </NavLink>
            <NavLink class="nav-item" href="fornecedores">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>
                </svg>
                <span>Fornecedores</span>
            </NavLink>
            <NavLink class="nav-item" href="transportadoras">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
                <span>Transportadoras</span>
            </NavLink>

            <div class="nav-section-label">Estoque</div>
            <NavLink class="nav-item" href="produtos">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                </svg>
                <span>Produtos</span>
            </NavLink>
            <NavLink class="nav-item" href="marcas">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
                </svg>
                <span>Marcas</span>
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">U</div>
                <div class="user-info">
                    <span class="user-name">Usuário</span>
                    <span class="user-role">Administrador</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- Overlay mobile -->
    <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>

    <!-- Main area -->
    <div class="erp-main">
        <header class="erp-topbar">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-brand-mobile">GestãoPro</div>
            <div class="topbar-spacer"></div>
            <div class="topbar-actions">
                <div class="topbar-badge">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
                    </svg>
                </div>
                <div class="topbar-avatar">A</div>
            </div>
        </header>

        <main class="erp-content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool sidebarOpen = false;
    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
}
